# PostgreSQL Database Configuration (optional — if not set, app uses local SQLite)
DB_HOST=localhost
DB_PORT=5432
DB_USER=pm_user
DB_PASSWORD=pm_pass
DB_NAME=performance_db

# JWT secret for signing tokens (change for production)
JWT_SECRET=replace_this_with_a_strong_secret

# Optional AI/service keys (leave blank if not used)
GEMINI_API_KEY=
APP_URL=
 
# If set to true the server will seed demo accounts on first run. Keep disabled in production.
SEED_DEMO=false
